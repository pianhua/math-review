# MiniMax AI API Key (用于生成每日复习题目)
MINIMAX_API_KEY=your_minimax_api_key_here

# JWT Secret (用于用户认证，生产环境务必更换为强随机字符串)
JWT_SECRET=your_random_secret_here_change_in_production

# Server port
PORT=3000

# CORS allowed origins (逗号分隔，留空则默认 localhost:5173,localhost:3002)
# CORS_ORIGINS=https://your-domain.com
